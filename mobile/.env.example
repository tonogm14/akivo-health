# ─────────────────────────────────────────────────────────────
# Mobile app environment — copy to .env  (nunca commitear .env)
# ─────────────────────────────────────────────────────────────

# URL base del API.
# Dev local (misma red WiFi):  http://192.168.18.21:3000
# Dev con ngrok/tunnel HTTPS:  https://xxxx.ngrok-free.app
# Producción:                  https://api.doctorhouse.pe
EXPO_PUBLIC_API_BASE=http://192.168.18.21:3000

# ── Métodos de pago habilitados (true / false)
EXPO_PUBLIC_PAYMENT_YAPE_PLIN=true
EXPO_PUBLIC_PAYMENT_CULQI=true
EXPO_PUBLIC_PAYMENT_NIUBIZ=true
EXPO_PUBLIC_PAYMENT_PAGOEFECTIVO=true

# ── Yape / Plin — número, nombre y URL de la imagen del QR
EXPO_PUBLIC_YAPE_PHONE=999999999
EXPO_PUBLIC_YAPE_NAME=Doctor House
EXPO_PUBLIC_YAPE_QR_URL=https://tudominio.com/qr-yape.png
