# ─────────────────────────────────────────────────────────────
# Copy to .env  (never commit .env to git)
# ─────────────────────────────────────────────────────────────

# ── App
NODE_ENV=development
PORT=3000

# ── Database
DATABASE_URL=postgresql://dh_user:dh_pass@localhost:5432/doctorhouse

# ── Auth
JWT_SECRET=changeme_minimum_32_chars_here___________________

# ── CORS  (production: https://api.doctorhouse.pe)
CORS_ORIGIN=*

# ── API Security
# Comma-separated list of valid API keys (one per client app build)
API_KEYS=dev-key-change-in-production
# Shared secret used to verify HMAC-SHA256 request signatures
API_SIGNING_SECRET=changeme_minimum_32_chars_here___________________

# ─────────────────────────────────────────────────────────────
# Payment Gateways
# ─────────────────────────────────────────────────────────────

# ── Culqi  (primary card payments)
# Docs: https://docs.culqi.com
# Sandbox dashboard: https://integ-panel.culqi.com
CULQI_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
CULQI_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
CULQI_WEBHOOK_SECRET=wh_test_xxxxxxxxxxxxxxxxxxxx
# Sandbox:    https://api-sandbox.culqi.com/v2
# Production: https://api.culqi.com/v2
CULQI_BASE_URL=https://api-sandbox.culqi.com/v2

# ── Niubiz  (secondary card payments — Visa/VisaNet Peru)
# Docs: https://developer.niubiz.com.pe
# Sandbox dashboard: https://developers.niubiz.com.pe
NIUBIZ_MERCHANT_ID=123456789
NIUBIZ_USERNAME=your_niubiz_username
NIUBIZ_PASSWORD=your_niubiz_password
# Sandbox:    https://apistg.niubiz.com.pe
# Production: https://api.niubiz.com.pe
NIUBIZ_BASE_URL=https://apistg.niubiz.com.pe

# ── PagoEfectivo  (secondary — cash payments at pharmacies/banks)
# Docs: https://developer.pagoefectivo.pe
# Sandbox dashboard: https://sandbox.pagoefectivo.pe
PAGOEFECTIVO_CLIENT_ID=your_client_id
PAGOEFECTIVO_CLIENT_SECRET=your_client_secret
PAGOEFECTIVO_SERVICE_ID=your_service_id
# Sandbox:    https://api-stg.pagoefectivo.pe
# Production: https://api.pagoefectivo.pe
PAGOEFECTIVO_BASE_URL=https://api-stg.pagoefectivo.pe

# ─────────────────────────────────────────────────────────────
# Firebase Cloud Messaging (push notifications)
# Obtener desde: Firebase Console → Configuración del proyecto →
#   Cuentas de servicio → Generar nueva clave privada
# ─────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=tu-proyecto-firebase
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu-proyecto.iam.gserviceaccount.com
# Copia la clave privada tal cual del JSON (incluye -----BEGIN/END PRIVATE KEY-----)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=tu-proyecto.firebasestorage.app

# ─────────────────────────────────────────────────────────────
# Email (Nodemailer SMTP)
# Used for: new application notifications, doctor welcome emails
# ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@doctorhouse.pe
SMTP_PASS=your_smtp_password_or_app_key
SMTP_FROM="Doctor House <noreply@doctorhouse.pe>"
ADMIN_EMAIL=admin@doctorhouse.pe

# ─────────────────────────────────────────────────────────────
# Admin
# ─────────────────────────────────────────────────────────────
# Token used to access admin-only endpoints (GET/POST /apply)
# Use a strong random value in production: openssl rand -hex 32
ADMIN_TOKEN=changeme_strong_random_token_here

# ── Dominios / CORS
# Dominio del panel admin (para robots.txt y CORS)
ADMIN_DOMAIN=admin.doctorhouse.pe
MAIN_DOMAIN=doctorhouse.pe
# Origen permitido para las rutas /admin/* del API
# Si el admin está en la misma instancia: no se necesita
# Si el admin está en otra instancia (ej. Vercel): pon el dominio aquí
ADMIN_CORS_ORIGIN=https://admin.doctorhouse.pe
